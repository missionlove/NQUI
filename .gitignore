# ===== Qt/qmake generated =====
**/.qmake.stash
**/Makefile
**/Makefile.Debug
**/Makefile.Release

# Qt Creator / user-local settings
**/*.pro.user
**/*.pro.user.*

# ===== Build output directories =====
/NQUI/build/
/NQUI/dist/

# ===== C/C++ objects and debug =====
**/*.obj
**/*.o
**/*.lo
**/*.pch
**/*.ilk
**/*.idb
**/*.pdb

# ===== Binaries / libraries =====
**/*.exe
**/*.dll
**/*.so
**/*.dylib
**/*.a
**/*.lib
**/*.exp

# ===== Qt auto-generated files =====
**/moc_*.cpp
**/qrc_*.cpp
**/ui_*.h
